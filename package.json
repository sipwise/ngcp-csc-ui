{
  "name": "ngcp-csc-ui",
  "version": "0.0.1",
  "description": "A Quasar Framework app",
  "productName": "Customer Self-Care Web Interface",
  "author": "Hans-Peter Herzog <hherzog@sipwise.com>",
  "private": true,
  "scripts": {
    "lint": "eslint .",
    "test": "echo \"See package.json => scripts for available tests.\" && exit 0",
    "config": "sh ./bin/config-create.sh",
    "upgrade": "quasar upgrade",
    "upgrade:conduct": "quasar upgrade -i",
    "build": "quasar build",
    "dev": "quasar dev",
    "dev:docker": "sh ./bin/run-docker.sh",
    "docker:rebuild:local": "docker build -f t/Dockerfile . -t ngcp-csc-ui-trixie",
    "docker:run:local": "sh ./bin/run-docker.sh local",
    "test:unit": "jest --updateSnapshot",
    "test:unit:coverage": "jest --coverage",
    "test:unit:watch": "jest --watch",
    "test:unit:watchAll": "jest --watchAll",
    "serve:test:coverage": "quasar serve test/jest/coverage/lcov-report/ --port 8788",
    "concurrently:dev:jest": "concurrently \"quasar dev\" \"jest --watch\"",
    "new:store": "quasar new store",
    "i18n:extract": "sh ./bin/vue-i18n-extract/extract.sh",
    "i18n:extract-report": "sh ./bin/vue-i18n-extract/extract.sh report"
  },
  "dependencies": {
    "@quasar/extras": "^1.16.12",
    "@vuelidate/core": "2.0.3",
    "@vuelidate/validators": "2.0.4",
