    "axios": "1.18.1",
    "content-disposition": "^2.0.1",
    "core-js": "^3.47.0",
    "decode-uri-component": "^0.5.0",
    "eslint-plugin-no-relative-import-paths": "1.6.1",
    "eslint-plugin-unused-imports": "4.4.1",
    "file-saver": "^2.0.2",
    "jest-junit": "^17.0.0",
    "jssip": "3.13.8",
    "load-script": "^2.0.0",
    "loader-utils": "^3.2.1",
    "lodash": "4.18.1",
    "moment": "^2.29.4",
    "path": "0.12.7",
    "qrcode": "1.5.4",
    "quasar": "2.21.2",
    "stream-browserify": "^3.0.0",
    "terser": "^5.49.0",
    "tiny-emitter": "2.1.0",
    "vue": "3.5.39",
    "vue-eslint-parser": "10.4.1",
