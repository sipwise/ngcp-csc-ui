    "@quasar/quasar-app-extension-testing": "2.2.0",
    "@quasar/quasar-app-extension-testing-unit-jest": "3.0.3",
    "@stylistic/eslint-plugin": "5.10.0",
    "@vue/test-utils": "2.4.11",
    "autoprefixer": "10.5.2",
    "commander": "15.0.0",
