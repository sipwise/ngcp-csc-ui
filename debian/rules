#!/usr/bin/make -f

# Uncomment this to turn on verbose mode.
#export DH_VERBOSE = 1

export NODE_PATH = /usr/lib/nodejs:/usr/share/nodejs

YARN_BIN := ".yarn/releases/yarn-4.17.1.cjs"

%:
	dh "$@"

override_dh_auto_install:
	$(YARN_BIN) install
	cp src/config/app.template.js src/config/app.js
	$(YARN_BIN) run build
	mv dist/spa csc
